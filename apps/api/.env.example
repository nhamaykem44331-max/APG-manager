# APG Manager RMS - Backend Environment Variables
# Copy file này thành .env và điền giá trị thực

# Database
DATABASE_URL="postgresql://apg:your_password@localhost:5432/apg_manager"

# JWT
JWT_SECRET="your-super-secret-jwt-key-at-least-256-bits-long-change-this"
JWT_EXPIRES_IN="8h"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=development

# AbayEngine (flight scraping)
ABAY_ENGINE_URL="http://localhost:3002"

# n8n Webhooks (VPS TinoHost)
N8N_WEBHOOK_URL="http://103.142.27.27:5678/webhook"

# AI (Claude API)
ANTHROPIC_API_KEY="sk-ant-your-key-here"

# Telegram
TELEGRAM_BOT_TOKEN="your-bot-token"
TELEGRAM_CHAT_ID="your-chat-id"

# Zalo OA
ZALO_OA_ACCESS_TOKEN="your-zalo-token"
ZALO_OA_REFRESH_TOKEN="your-refresh-token"

# MISA (Phase 2)
# MISA_API_KEY="your-misa-key"
# MISA_COMPANY_CODE="your-company-code"
