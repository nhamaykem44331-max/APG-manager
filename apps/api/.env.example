# API Environment Variables
DATABASE_URL="postgresql://postgres:password@localhost:5432/apg_manager?schema=public"

# JWT Auth
JWT_SECRET="generate-a-random-64-character-string-here"
JWT_REFRESH_SECRET="generate-another-random-64-character-string-here"

# Frontend URL for CORS
FRONTEND_URL="http://localhost:3000"

# Application
PORT=3001
NODE_ENV="development"

# Gemini AI (Smart Ticket Import)
GEMINI_API_KEY="your-gemini-api-key-here"
GEMINI_MODEL="gemini-3-flash-preview"

# Google Sheets Sync (Đồng bộ bảng Thống kê Vé FIT)
GOOGLE_SERVICE_ACCOUNT_EMAIL="your-service-account@project.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-key-here\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID="your-google-sheet-id"
GOOGLE_SHEET_NAME="Thống kê Vé FIT"

# n8n Automation (tuỳ chọn)
N8N_WEBHOOK_BASE_URL="http://localhost:5678/webhook"
